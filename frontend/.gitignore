# ─────────────────────────────────────────────
#  MindWave Frontend — Next.js .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────
.next/
out/
build/
dist/

# ── Environment files ─────────────────────────
# Commit .env.example but never real secrets
.env
.env.*
!.env.example

# ── Testing / Coverage ────────────────────────
coverage/
.nyc_output/

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ────────────────────────────────────
.vercel

# ── Logs ──────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
